# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (for Gmail draft creation)
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: http://localhost:3000/api/auth/callback
# 4. Enable Gmail API in APIs & Services → Library
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# After running the OAuth flow once (visit /api/auth/init), paste the refresh token here:
GOOGLE_REFRESH_TOKEN=
